config { type: "assertion", tags: ["gold", "assertion", "adherence"] }

SELECT
  userId,
  reference_month,
  CASE
    WHEN days_active > 0 AND sessions < days_active     THEN 'sessions < days_active'
    WHEN courses_completed_month > courses_started_month THEN 'courses_completed > courses_started'
  END AS failure_reason
FROM ${ref("gold_user_adherence")}
WHERE
  (days_active > 0 AND sessions < days_active)
  OR (courses_completed_month > courses_started_month)