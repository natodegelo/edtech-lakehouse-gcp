config { type: "assertion", tags: ["gold", "assertion", "adherence"] }

WITH label_dist AS (
  SELECT
    adherence_label,
    COUNT(*) AS qty,
    SUM(COUNT(*)) OVER () AS total
  FROM ${ref("gold_user_adherence")}
  WHERE reference_month = DATE_TRUNC(CURRENT_DATE(), MONTH)
  GROUP BY 1
)
SELECT adherence_label, qty, total, ROUND(qty / total, 4) AS pct_share
FROM label_dist
WHERE adherence_label = 'inativo' AND (qty / total) > 0.70