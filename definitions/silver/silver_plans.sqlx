config {
  type: "table",
  schema: "silver_dev",
  name: "silver_plans",
  description: "Planos da plataforma LearnHub",
  tags: ["silver", "plans"]
}

SELECT
  planId,
  name,
  description,
  hierarchy,
  color,
  trialAvailable,

  CURRENT_TIMESTAMP()   AS _transformed_at,
  '1.0.0'              AS _pipeline_version

FROM ${ref("plans")}

WHERE planId IS NOT NULL